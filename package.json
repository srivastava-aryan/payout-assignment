{
  "name": "faym-payout-system",
  "version": "1.0.0",
  "description": "LLD + implementation of the Faym SDE Intern assignment: user payout management with advance payouts, reconciliation, and withdrawal handling.",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "demo": "node demo/runDemo.js",
